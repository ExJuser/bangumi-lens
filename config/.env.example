DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Optional but recommended by Bangumi for non-browser API clients. Replace "your-bangumi-id" with your developer/user ID.
BANGUMI_USER_AGENT=your-bangumi-id/bangumi-lens/0.1.0 (https://github.com/local/bangumi-lens)
# Optional. Used for authenticated Bangumi API requests, including restricted/NSFW API data visible to your account.
BANGUMI_ACCESS_TOKEN=your-bangumi-access-token
# Optional. Use this when Node cannot reach Bangumi/OpenAI directly.
BANGUMI_LENS_PROXY=http://127.0.0.1:7897
